</person-group><article-title>Kidney-sparing surgery for upper tract urothelial cancer</article-title><source>Curr. Opin. Urol.</source><year>2015</year><volume>25</volume><fpage>100</fpage><lpage>104</lpage><pub-id pub-id-type="doi">10.1097/MOU.0000000000000148</pub-id><pub-id pub-id-type="pmid">25581542</pub-id></element-citation></ref><ref id="B11-cancers-15-01373"><label>11.</label><element-citation publication-type="journal"><person-group person-group-type="author">
<name><surname>Seisen</surname><given-names>T.</given-names></name>
